<div class="split-page split-inventory compact-list">

  {{!-- Currency --}}
  <div class="currency-bar compact">
    <div class="currency-chip pp"><span class="curr-label">PP</span>
      <input type="number" name="system.currency.pp" value="{{currency.pp}}" {{#unless isEditable}}disabled{{/unless}}></div>
    <div class="currency-chip gp"><span class="curr-label">GP</span>
      <input type="number" name="system.currency.gp" value="{{currency.gp}}" {{#unless isEditable}}disabled{{/unless}}></div>
    <div class="currency-chip sp"><span class="curr-label">SP</span>
      <input type="number" name="system.currency.sp" value="{{currency.sp}}" {{#unless isEditable}}disabled{{/unless}}></div>
    <div class="currency-chip cp"><span class="curr-label">CP</span>
      <input type="number" name="system.currency.cp" value="{{currency.cp}}" {{#unless isEditable}}disabled{{/unless}}></div>
  </div>

  {{!-- Weapons --}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">{{localize "DC20AltSheet.section.weapons"}}</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="weapon" title="{{localize "DC20AltSheet.create.weapon"}}">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  {{#if itemGroups.weapons.length}}
  <ul class="items-list">
    {{#each itemGroups.weapons}}
    <li class="item-row {{#if equipped}}equipped{{/if}}" data-item-id="{{id}}">
      <img class="item-img item-img-rollable" src="{{img}}" alt="{{name}}" data-action="useItem" title="{{localize "DC20AltSheet.use"}} {{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        <button type="button" class="{{#if equipped}}active{{/if}}"
          data-action="toggleEquip" data-item-id="{{id}}" title="{{localize "DC20AltSheet.equip"}}">
          <i class="fas fa-shield-alt"></i>
        </button>
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.delete"}}">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="empty-note">{{localize "DC20AltSheet.empty.weapons"}}</p>
  {{/if}}

  {{!-- Equipment --}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">{{localize "DC20AltSheet.section.equipment"}}</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="equipment" title="{{localize "DC20AltSheet.create.equipment"}}">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  {{#if itemGroups.equipment.length}}
  <ul class="items-list">
    {{#each itemGroups.equipment}}
    <li class="item-row {{#if equipped}}equipped{{/if}}" data-item-id="{{id}}">
      <img class="item-img" src="{{img}}" alt="{{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        <button type="button" class="{{#if equipped}}active{{/if}}"
          data-action="toggleEquip" data-item-id="{{id}}" title="{{localize "DC20AltSheet.equip"}}">
          <i class="fas fa-shield-alt"></i>
        </button>
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.delete"}}">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="empty-note">{{localize "DC20AltSheet.empty.equipment"}}</p>
  {{/if}}

  {{!-- Consumables --}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">{{localize "DC20AltSheet.section.consumables"}}</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="consumable" title="{{localize "DC20AltSheet.create.consumable"}}">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  {{#if itemGroups.consumables.length}}
  <ul class="items-list">
    {{#each itemGroups.consumables}}
    <li class="item-row" data-item-id="{{id}}">
      <img class="item-img item-img-rollable" src="{{img}}" alt="{{name}}" data-action="useItem" title="{{localize "DC20AltSheet.use"}} {{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.delete"}}">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="empty-note">{{localize "DC20AltSheet.empty.consumables"}}</p>
  {{/if}}

  {{!-- Loot --}}
  {{#if itemGroups.loot.length}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">{{localize "DC20AltSheet.section.loot"}}</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="loot" title="{{localize "DC20AltSheet.create.loot"}}">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  <ul class="items-list">
    {{#each itemGroups.loot}}
    <li class="item-row" data-item-id="{{id}}">
      <img class="item-img" src="{{img}}" alt="{{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.delete"}}">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{/if}}

</div>
