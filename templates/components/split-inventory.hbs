<div class="split-page split-inventory compact-list">

  {{!-- Currency --}}
  <div class="currency-bar compact">
    <div class="currency-chip pp"><span class="curr-label">PP</span>
      <input type="number" name="system.currency.pp" value="{{currency.pp}}" {{#unless isEditable}}disabled{{/unless}}></div>
    <div class="currency-chip gp"><span class="curr-label">GP</span>
      <input type="number" name="system.currency.gp" value="{{currency.gp}}" {{#unless isEditable}}disabled{{/unless}}></div>
    <div class="currency-chip sp"><span class="curr-label">SP</span>
      <input type="number" name="system.currency.sp" value="{{currency.sp}}" {{#unless isEditable}}disabled{{/unless}}></div>
    <div class="currency-chip cp"><span class="curr-label">CP</span>
      <input type="number" name="system.currency.cp" value="{{currency.cp}}" {{#unless isEditable}}disabled{{/unless}}></div>
  </div>

  {{!-- Weapons --}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">Weapons</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="weapon" title="Add Weapon">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  {{#if itemGroups.weapons.length}}
  <ul class="items-list">
    {{#each itemGroups.weapons}}
    <li class="item-row {{#if equipped}}equipped{{/if}}" data-item-id="{{id}}">
      <img class="item-img" src="{{img}}" alt="{{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        <button type="button" class="{{#if equipped}}active{{/if}}"
          data-action="toggleEquip" data-item-id="{{id}}" title="Equip/Unequip">
          <i class="fas fa-shield-alt"></i>
        </button>
        <button type="button" data-action="useItem" data-item-id="{{id}}" title="Use">
          <i class="fas fa-play"></i>
        </button>
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="Delete">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="empty-note">No weapons.</p>
  {{/if}}

  {{!-- Equipment --}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">Equipment</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="equipment" title="Add Equipment">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  {{#if itemGroups.equipment.length}}
  <ul class="items-list">
    {{#each itemGroups.equipment}}
    <li class="item-row {{#if equipped}}equipped{{/if}}" data-item-id="{{id}}">
      <img class="item-img" src="{{img}}" alt="{{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        <button type="button" class="{{#if equipped}}active{{/if}}"
          data-action="toggleEquip" data-item-id="{{id}}" title="Equip/Unequip">
          <i class="fas fa-shield-alt"></i>
        </button>
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="Delete">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="empty-note">No equipment.</p>
  {{/if}}

  {{!-- Consumables --}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">Consumables</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="consumable" title="Add Consumable">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  {{#if itemGroups.consumables.length}}
  <ul class="items-list">
    {{#each itemGroups.consumables}}
    <li class="item-row" data-item-id="{{id}}">
      <img class="item-img" src="{{img}}" alt="{{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        <button type="button" data-action="useItem" data-item-id="{{id}}" title="Use">
          <i class="fas fa-play"></i>
        </button>
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="Delete">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="empty-note">No consumables.</p>
  {{/if}}

  {{!-- Loot --}}
  {{#if itemGroups.loot.length}}
  <div class="item-section-hdr mt">
    <h4 class="section-heading">Loot</h4>
    {{#if isEditable}}
    <button type="button" class="add-btn icon-btn" data-action="createItem" data-type="loot" title="Add Loot">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </div>
  <ul class="items-list">
    {{#each itemGroups.loot}}
    <li class="item-row" data-item-id="{{id}}">
      <img class="item-img" src="{{img}}" alt="{{name}}">
      <span class="item-name">{{name}}</span>
      <span class="item-qty muted">×{{quantity}}</span>
      <div class="item-controls">
        {{#if ../isEditable}}
        <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="Delete">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </li>
    {{/each}}
  </ul>
  {{/if}}

</div>
