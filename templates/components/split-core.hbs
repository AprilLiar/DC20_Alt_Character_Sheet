<div class="split-page split-core">

  {{!-- Compact attribute cards — full name + two roll buttons --}}
  <div class="sc-attrs">
    {{#each attributes}}
    <div class="sc-attr" data-attr="{{key}}">
      <span class="sc-attr-name">{{label}}</span>
      <div class="sc-attr-buttons">
        <button type="button" class="sc-attr-btn rollable" data-action="rollAttribute" data-attr="{{key}}" title="Check">
          <i class="fas fa-dice-d20"></i>{{signedNum check}}
        </button>
        <button type="button" class="sc-attr-btn rollable" data-action="rollSave" data-attr="{{key}}" title="Save">
          <i class="fas fa-shield-alt"></i>{{signedNum save}}
        </button>
      </div>
    </div>
    {{/each}}
  </div>

  {{!-- Knowledge half: Skills + Trades + Languages in rounded panels --}}
  <div class="sc-knowledge">

    {{!-- Skills panel: only proficient (mastery > 0), grouped by attribute --}}
    <div class="sc-panel">
      <div class="sc-panel-heading">Skills</div>
      <div class="sc-skill-grid">
        {{#each skillGroupsMastered}}
        {{#if items.length}}
        <div class="sc-attr-group-label">{{label}}</div>
        {{#each items}}
        <div class="sc-skill-row rollable" data-action="rollSkill" data-skill="{{key}}" title="{{label}}">
          <span class="sc-skill-name">{{label}}</span>
          <span class="sc-skill-bonus">{{signedNum bonus}}</span>
        </div>
        {{/each}}
        {{/if}}
        {{/each}}
      </div>
    </div>

    {{!-- Trades + Languages side by side --}}
    {{#if (or tradeGroupsMastered.length languages.length)}}
    <div class="sc-panel-row">
      {{#if tradeGroupsMastered.length}}
      <div class="sc-panel">
        <div class="sc-panel-heading">Trades</div>
        {{#each tradeGroupsMastered}}
        {{#if items.length}}
        <div class="sc-attr-group-label">{{label}}</div>
        {{#each items}}
        <div class="sc-skill-row">
          <span class="sc-skill-name">{{label}}</span>
          <span class="sc-skill-bonus">{{signedNum bonus}}</span>
        </div>
        {{/each}}
        {{/if}}
        {{/each}}
      </div>
      {{/if}}
      {{#if languages.length}}
      <div class="sc-panel">
        <div class="sc-panel-heading">Languages</div>
        {{#each languages}}
        <div class="sc-skill-row">
          <span class="sc-skill-name">{{label}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </div>
    {{/if}}

  </div>

  {{!-- Items half: Favourites + Last Used in rounded panels --}}
  <div class="sc-items-grid">
    <div class="sc-panel">
      <div class="sc-panel-heading">Favourites</div>
      {{#if favourites.length}}
        {{#each favourites}}
        <div class="sc-item-row" data-item-id="{{id}}">
          <img class="sc-item-img" src="{{img}}" alt="{{name}}" data-action="useItem" data-item-id="{{id}}" title="Use {{name}}">
          <span class="sc-item-name">{{name}}</span>
        </div>
        {{/each}}
      {{else}}
        <p class="empty-note">—</p>
      {{/if}}
    </div>
    <div class="sc-panel">
      <div class="sc-panel-heading">Last Used</div>
      {{#if lastUsed.length}}
        {{#each lastUsed}}
        <div class="sc-item-row" data-item-id="{{id}}">
          <img class="sc-item-img" src="{{img}}" alt="{{name}}" data-action="useItem" data-item-id="{{id}}" title="Use {{name}}">
          <span class="sc-item-name">{{name}}</span>
        </div>
        {{/each}}
      {{else}}
        <p class="empty-note">—</p>
      {{/if}}
    </div>
  </div>

</div>
