<section class="page-scroll" data-page="combat">

  {{!-- Filter Tabs --}}
  <div class="combat-filter-bar">
    <button type="button"
      class="combat-filter-btn {{#if (eq combatFilter 'all')}}active{{/if}}"
      data-filter="all">{{localize "DC20AltSheet.combat.filterAll"}}</button>
    <button type="button"
      class="combat-filter-btn {{#if (eq combatFilter 'weapon')}}active{{/if}}"
      data-filter="weapon">{{localize "DC20AltSheet.combat.filterWeapon"}}</button>
    <button type="button"
      class="combat-filter-btn {{#if (eq combatFilter 'equipment')}}active{{/if}}"
      data-filter="equipment">{{localize "DC20AltSheet.combat.filterEquipment"}}</button>
    <button type="button"
      class="combat-filter-btn {{#if (eq combatFilter 'spell')}}active{{/if}}"
      data-filter="spell">{{localize "DC20AltSheet.combat.filterSpell"}}</button>
    <button type="button"
      class="combat-filter-btn {{#if (eq combatFilter 'maneuver')}}active{{/if}}"
      data-filter="maneuver">{{localize "DC20AltSheet.combat.filterManeuver"}}</button>
    <button type="button"
      class="combat-filter-btn {{#if (eq combatFilter 'feature')}}active{{/if}}"
      data-filter="feature">{{localize "DC20AltSheet.combat.filterFeature"}}</button>
  </div>

  {{!-- Per-filter Create buttons (shown only when a specific filter is active) --}}
  {{#if isEditable}}
  <div class="combat-create-bar">
    <button type="button" class="combat-create-btn hidden" data-create-filter="weapon"   data-action="createItem" data-type="weapon">
      <i class="fas fa-plus"></i> {{localize "DC20AltSheet.combat.createWeapon"}}
    </button>
    <button type="button" class="combat-create-btn hidden" data-create-filter="equipment" data-action="createItem" data-type="equipment">
      <i class="fas fa-plus"></i> {{localize "DC20AltSheet.combat.createEquipment"}}
    </button>
    <button type="button" class="combat-create-btn hidden" data-create-filter="spell"    data-action="createItem" data-type="spell">
      <i class="fas fa-plus"></i> {{localize "DC20AltSheet.combat.createSpell"}}
    </button>
    <button type="button" class="combat-create-btn hidden" data-create-filter="maneuver" data-action="createItem" data-type="maneuver">
      <i class="fas fa-plus"></i> {{localize "DC20AltSheet.combat.createManeuver"}}
    </button>
    <button type="button" class="combat-create-btn hidden" data-create-filter="feature"  data-action="createItem" data-type="feature">
      <i class="fas fa-plus"></i> {{localize "DC20AltSheet.combat.createFeature"}}
    </button>
  </div>
  {{/if}}

  {{!-- Combat Actions --}}
  <div class="combat-actions" data-reorder-list data-reorder-mode="sort">
    {{#each combatActions}}
    <div class="combat-action-row{{#if isEquipped}} equipped{{/if}}{{#if isAttuned}} attuned{{/if}}" data-item-id="{{id}}" data-filter-type="{{filterType}}">
      <img class="ca-img" src="{{img}}" alt="{{name}}"
        data-action="useItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.use"}} {{name}}">
      <span class="ca-name">{{name}}</span>
      <span class="ca-type">{{filterType}}</span>
      <span class="ca-cost muted">{{itemCost costs}}</span>
      {{#if rangeType}}<span class="ca-range muted">{{rangeType}}</span>{{/if}}
      {{#if attackBonus}}<span class="ca-atk">{{signedNum attackBonus}}</span>{{/if}}
      <div class="ca-controls">
        <button type="button" class="ca-btn equip-btn{{#if isEquipped}} active{{/if}}"
          data-action="toggleEquip" data-item-id="{{id}}"
          title="{{#if isEquipped}}{{localize "DC20AltSheet.combat.unequip"}}{{else}}{{localize "DC20AltSheet.combat.equip"}}{{/if}}">
          <i class="fas fa-shield-alt"></i>
        </button>
        {{#if canAttune}}
        <button type="button" class="ca-btn attune-btn{{#if isAttuned}} active{{/if}}"
          data-action="toggleAttune" data-item-id="{{id}}"
          title="{{#if isAttuned}}{{localize "DC20AltSheet.combat.unattune"}}{{else}}{{localize "DC20AltSheet.combat.attune"}}{{/if}}">
          <i class="fas fa-gem"></i>
        </button>
        {{/if}}
        {{#if ../isEditable}}
        <button type="button" class="ca-btn del-btn"
          data-action="deleteItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.delete"}}">
          <i class="fas fa-trash"></i>
        </button>
        {{/if}}
      </div>
    </div>
    {{else}}
    <p class="empty-note">{{localize "DC20AltSheet.empty.combat"}}</p>
    {{/each}}
  </div>

</section>
