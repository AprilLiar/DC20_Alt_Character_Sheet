<div class="tab tab-body" data-group="primary" data-tab="tab-inventory">

  <!-- Currency -->
  <div class="currency-row">
    <div class="currency-chip pp">
      <span class="curr-label">PP</span>
      <input type="number" name="system.currency.pp" value="{{currency.pp}}"
        {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="currency-chip gp">
      <span class="curr-label">GP</span>
      <input type="number" name="system.currency.gp" value="{{currency.gp}}"
        {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="currency-chip sp">
      <span class="curr-label">SP</span>
      <input type="number" name="system.currency.sp" value="{{currency.sp}}"
        {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="currency-chip cp">
      <span class="curr-label">CP</span>
      <input type="number" name="system.currency.cp" value="{{currency.cp}}"
        {{#unless isEditable}}disabled{{/unless}}>
    </div>
  </div>

  <!-- Weapons -->
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.weapons"}}</h3>
      {{#if isEditable}}
      <button type="button" class="create-item-btn" data-action="createItem" data-type="weapon">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if weapons.length}}
    <ul class="items-list">
      {{#each weapons}}
      <li class="item-row {{#if system.statuses.equipped}}equipped{{/if}}" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-type muted">{{system.weaponType}}</span>
        <span class="item-detail muted">{{system.attackFormula.rangeType}}</span>
        <div class="item-controls">
          <button type="button" data-action="toggleEquip"
            title="{{localize "DC20AltSheet.equip"}}"
            class="{{#if system.statuses.equipped}}active{{/if}}">
            <i class="fas fa-shield-alt"></i>
          </button>
          <button type="button" data-action="useItem"><i class="fas fa-play"></i></button>
          <button type="button" data-action="editItem"><i class="fas fa-pencil-alt"></i></button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem"><i class="fas fa-trash"></i></button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">{{localize "DC20AltSheet.empty.weapons"}}</p>
    {{/if}}
  </div>

  <!-- Equipment -->
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.equipment"}}</h3>
      {{#if isEditable}}
      <button type="button" class="create-item-btn" data-action="createItem" data-type="equipment">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if equipment.length}}
    <ul class="items-list">
      {{#each equipment}}
      <li class="item-row {{#if system.statuses.equipped}}equipped{{/if}}" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-type muted">{{system.equipmentType}}</span>
        <span class="item-detail muted">{{system.quantity}}</span>
        <div class="item-controls">
          <button type="button" data-action="toggleEquip"
            class="{{#if system.statuses.equipped}}active{{/if}}">
            <i class="fas fa-shield-alt"></i>
          </button>
          <button type="button" data-action="editItem"><i class="fas fa-pencil-alt"></i></button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem"><i class="fas fa-trash"></i></button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">{{localize "DC20AltSheet.empty.equipment"}}</p>
    {{/if}}
  </div>

  <!-- Consumables -->
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.consumables"}}</h3>
      {{#if isEditable}}
      <button type="button" class="create-item-btn" data-action="createItem" data-type="consumable">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if consumables.length}}
    <ul class="items-list">
      {{#each consumables}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-type muted">{{system.consumableType}}</span>
        <span class="item-qty muted">×{{system.quantity}}</span>
        <div class="item-controls">
          <button type="button" data-action="useItem"><i class="fas fa-play"></i></button>
          <button type="button" data-action="editItem"><i class="fas fa-pencil-alt"></i></button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem"><i class="fas fa-trash"></i></button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">{{localize "DC20AltSheet.empty.consumables"}}</p>
    {{/if}}
  </div>

  <!-- Loot -->
  {{#if loot.length}}
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.loot"}}</h3>
    </div>
    <ul class="items-list">
      {{#each loot}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-qty muted">×{{system.quantity}}</span>
        <div class="item-controls">
          <button type="button" data-action="editItem"><i class="fas fa-pencil-alt"></i></button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem"><i class="fas fa-trash"></i></button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

</div>
