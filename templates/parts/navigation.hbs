<div class="browser-tabs-container">

  {{!-- Horizontal tab bar --}}
  <div class="browser-tab-bar">
    {{#each openTabs}}
    <div class="browser-tab{{#if active}} active{{/if}}{{#if isSplit}} split-tab{{/if}}"
         data-page="{{id}}"
         draggable="true">
      {{#if isSplit}}
        <span class="btab-split-icons">
          <span class="btab-icon btab-icon-{{leftId}}"></span>
          <span class="btab-split-sep">|</span>
          <span class="btab-icon btab-icon-{{rightId}}"></span>
          {{#if is3Pane}}
            <span class="btab-split-sep">+</span>
            <span class="btab-icon btab-icon-{{bottomId}}"></span>
          {{/if}}
        </span>
      {{else}}
        <span class="btab-icon btab-icon-{{id}}"></span>
      {{/if}}
      <span class="btab-label">{{label}}</span>
      <button type="button" class="btab-close" data-close-page="{{id}}" title="Close tab">×</button>
    </div>
    {{/each}}
    <button type="button" class="btab-add" title="Open page">+</button>
  </div>

  {{!-- Page picker overlay (shown when + is clicked) --}}
  <div class="tab-picker hidden">
    <div class="tab-picker-grid">
      {{#each pageDefs}}
      <button type="button" class="picker-item" data-open-page="{{id}}">
        <span class="btab-icon btab-icon-{{id}}"></span>
        <span class="picker-label">{{label}}</span>
      </button>
      {{/each}}
    </div>

    {{!-- Split-tab builder --}}
    <div class="split-builder">
      <div class="split-builder-header">
        <div class="split-builder-label">Splitscreen</div>
        <div class="split-orient-toggle">
          <button type="button" class="split-orient-btn active" data-orient="vertical" title="Side by side">⇔ Vertical</button>
          <button type="button" class="split-orient-btn" data-orient="horizontal" title="Top and bottom">⇕ Horizontal</button>
        </div>
      </div>
      <div class="split-zones-top-row">
        <div class="split-zone" data-split-side="left">
          <span class="split-zone-hint">drop a tab here…</span>
        </div>
        <div class="split-zone" data-split-side="right">
          <span class="split-zone-hint">drop a tab here…</span>
        </div>
      </div>
      <div class="split-bottom-wrap hidden">
        <div class="split-zone split-zone-full" data-split-side="bottom">
          <span class="split-zone-hint">optional bottom panel…</span>
        </div>
      </div>
      <button type="button" class="split-create-btn" disabled>Create Split</button>
    </div>
  </div>

</div>
