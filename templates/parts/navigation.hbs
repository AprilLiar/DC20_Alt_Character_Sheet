<div class="browser-tabs-container">

  {{!-- Horizontal tab bar --}}
  <div class="browser-tab-bar">
    {{#each openTabs}}
    <div class="browser-tab{{#if active}} active{{/if}}{{#if isSplit}} split-tab{{/if}}"
         data-page="{{id}}"
         draggable="true">
      <span class="btab-content">
        {{#if isSplit}}
          <span class="btab-split-icons">
            <span class="btab-icon btab-icon-{{leftId}}"></span>
            <span class="btab-split-sep">|</span>
            <span class="btab-icon btab-icon-{{rightId}}"></span>
            {{#if is3Pane}}
              <span class="btab-split-sep">+</span>
              <span class="btab-icon btab-icon-{{bottomId}}"></span>
            {{/if}}
            {{#if is4Pane}}
              <span class="btab-split-sep">+</span>
              <span class="btab-icon btab-icon-{{bottomId}}"></span>
              <span class="btab-split-sep">+</span>
              <span class="btab-icon btab-icon-{{bottomRightId}}"></span>
            {{/if}}
          </span>
        {{else}}
          <span class="btab-icon btab-icon-{{id}}"></span>
        {{/if}}
        <span class="btab-label">{{label}}</span>
      </span>
      <button type="button" class="btab-close" data-close-page="{{id}}" title="{{localize "DC20AltSheet.nav.closeTab"}}">×</button>
    </div>
    {{/each}}
    <button type="button" class="btab-add" title="{{localize "DC20AltSheet.nav.openPage"}}">+</button>
  </div>

  {{!-- Page picker overlay (shown when + is clicked) --}}
  <div class="tab-picker hidden">
    <div class="tab-picker-grid">
      {{#each pageDefs}}
      <button type="button" class="picker-item" data-open-page="{{id}}">
        <span class="btab-icon btab-icon-{{id}}"></span>
        <span class="picker-label">{{localize label}}</span>
      </button>
      {{/each}}
    </div>

    {{!-- Split-tab builder --}}
    <div class="split-builder">
      <div class="split-builder-header">
        <div class="split-builder-label">{{localize "DC20AltSheet.nav.splitscreen"}}</div>
        <div class="split-orient-toggle">
          <button type="button" class="split-orient-btn active" data-orient="vertical" title="{{localize "DC20AltSheet.nav.sideBySize"}}">{{localize "DC20AltSheet.nav.vertical"}}</button>
          <button type="button" class="split-orient-btn" data-orient="horizontal" title="{{localize "DC20AltSheet.nav.topAndBottom"}}">{{localize "DC20AltSheet.nav.horizontal"}}</button>
        </div>
      </div>
      <div class="split-zones-top-row">
        <div class="split-zone" data-split-side="left">
          <span class="split-zone-hint">{{localize "DC20AltSheet.nav.dropHere"}}</span>
        </div>
        <div class="split-zone" data-split-side="right">
          <span class="split-zone-hint">{{localize "DC20AltSheet.nav.dropHere"}}</span>
        </div>
      </div>
      <div class="split-bottom-wrap hidden">
        <div class="split-zones-bottom-row">
          <div class="split-zone" data-split-side="bottom">
            <span class="split-zone-hint">{{localize "DC20AltSheet.nav.optionalBottom"}}</span>
          </div>
          <div class="split-zone hidden" data-split-side="bottomRight">
            <span class="split-zone-hint">{{localize "DC20AltSheet.nav.optionalFourth"}}</span>
          </div>
        </div>
      </div>
      <button type="button" class="split-create-btn" disabled>{{localize "DC20AltSheet.nav.createSplit"}}</button>
    </div>
  </div>

</div>
