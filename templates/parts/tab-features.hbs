<div class="tab tab-body" data-group="primary" data-tab="tab-features">

  <!-- Known Limits Banner -->
  <div class="known-banner">
    <div class="known-chip spells">
      <i class="fas fa-hat-wizard"></i>
      {{localize "DC20AltSheet.known.spells"}}
      <strong>{{known.spells.current}}/{{known.spells.max}}</strong>
    </div>
    <div class="known-chip maneuvers">
      <i class="fas fa-swords"></i>
      {{localize "DC20AltSheet.known.maneuvers"}}
      <strong>{{known.maneuvers.current}}/{{known.maneuvers.max}}</strong>
    </div>
    <div class="known-chip infusions">
      <i class="fas fa-flask"></i>
      {{localize "DC20AltSheet.known.infusions"}}
      <strong>{{known.infusions.current}}/{{known.infusions.max}}</strong>
    </div>
  </div>

  <!-- Features -->
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.features"}}</h3>
      {{#if isEditable}}
      <button type="button" class="create-item-btn" data-action="createItem" data-type="feature"
        title="{{localize "DC20AltSheet.create.feature"}}">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if features.length}}
    <ul class="items-list">
      {{#each features}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-type muted">{{system.featureType}}</span>
        {{#if system.costs}}
        <span class="item-cost muted">{{itemCost system.costs}}</span>
        {{/if}}
        <div class="item-controls">
          <button type="button" data-action="useItem" title="{{localize "DC20AltSheet.use"}}">
            <i class="fas fa-play"></i>
          </button>
          <button type="button" data-action="editItem" title="{{localize "DC20AltSheet.edit"}}">
            <i class="fas fa-pencil-alt"></i>
          </button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem" title="{{localize "DC20AltSheet.delete"}}">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">{{localize "DC20AltSheet.empty.features"}}</p>
    {{/if}}
  </div>

  <!-- Maneuvers -->
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.maneuvers"}}</h3>
      {{#if isEditable}}
      <button type="button" class="create-item-btn" data-action="createItem" data-type="maneuver">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if maneuvers.length}}
    <ul class="items-list">
      {{#each maneuvers}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-type muted">{{system.maneuverType}}</span>
        <span class="item-cost muted">{{itemCost system.costs}}</span>
        <div class="item-controls">
          <button type="button" data-action="useItem"><i class="fas fa-play"></i></button>
          <button type="button" data-action="editItem"><i class="fas fa-pencil-alt"></i></button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem"><i class="fas fa-trash"></i></button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">{{localize "DC20AltSheet.empty.maneuvers"}}</p>
    {{/if}}
  </div>

  <!-- Spells -->
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.spells"}}</h3>
      {{#if isEditable}}
      <button type="button" class="create-item-btn" data-action="createItem" data-type="spell">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if spells.length}}
    <ul class="items-list">
      {{#each spells}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-type muted">{{system.spellType}}</span>
        <span class="item-cost muted">{{itemCost system.costs}}</span>
        <div class="item-controls">
          <button type="button" data-action="useItem"><i class="fas fa-play"></i></button>
          <button type="button" data-action="editItem"><i class="fas fa-pencil-alt"></i></button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem"><i class="fas fa-trash"></i></button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">{{localize "DC20AltSheet.empty.spells"}}</p>
    {{/if}}
  </div>

  <!-- Techniques -->
  {{#if techniques.length}}
  <div class="item-section">
    <div class="item-section-header">
      <h3 class="section-title">{{localize "DC20AltSheet.section.techniques"}}</h3>
    </div>
    <ul class="items-list">
      {{#each techniques}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-cost muted">{{itemCost system.costs}}</span>
        <div class="item-controls">
          <button type="button" data-action="useItem"><i class="fas fa-play"></i></button>
          <button type="button" data-action="editItem"><i class="fas fa-pencil-alt"></i></button>
          {{#if ../isEditable}}
          <button type="button" data-action="deleteItem"><i class="fas fa-trash"></i></button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

</div>
