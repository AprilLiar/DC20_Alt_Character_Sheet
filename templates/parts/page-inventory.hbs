<section class="page-scroll" data-page="inventory">

  {{!-- Currency --}}
  <div class="currency-bar">
    <div class="currency-chip pp">
      <span class="curr-label">PP</span>
      <input type="number" name="system.currency.pp"
        value="{{currency.pp}}" {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="currency-chip gp">
      <span class="curr-label">GP</span>
      <input type="number" name="system.currency.gp"
        value="{{currency.gp}}" {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="currency-chip sp">
      <span class="curr-label">SP</span>
      <input type="number" name="system.currency.sp"
        value="{{currency.sp}}" {{#unless isEditable}}disabled{{/unless}}>
    </div>
    <div class="currency-chip cp">
      <span class="curr-label">CP</span>
      <input type="number" name="system.currency.cp"
        value="{{currency.cp}}" {{#unless isEditable}}disabled{{/unless}}>
    </div>
  </div>

  {{!-- Weapons --}}
  <div class="item-section">
    <div class="item-section-hdr">
      <h3 class="section-heading">Weapons</h3>
      {{#if isEditable}}
      <button type="button" class="add-btn icon-btn"
        data-action="createItem" data-type="weapon" title="Add Weapon">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if itemGroups.weapons.length}}
    <ul class="items-list" data-reorder-list data-reorder-mode="sort">
      {{#each itemGroups.weapons}}
      <li class="item-row{{#if equipped}} equipped{{/if}}{{#if attuned}} attuned{{/if}}" data-item-id="{{id}}">
        <img class="item-img item-img-rollable" src="{{img}}" alt="{{name}}" data-action="useItem" title="Use {{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-tag muted">{{weaponType}}{{#if rangeType}} · {{rangeType}}{{/if}}</span>
        <span class="item-qty muted">×{{quantity}}</span>
        <div class="item-controls">
          <button type="button" class="{{#if equipped}}active{{/if}}"
            data-action="toggleEquip" data-item-id="{{id}}" title="Equip/Unequip">
            <i class="fas fa-shield-alt"></i>
          </button>
          {{#if ../isEditable}}
          <button type="button"
            data-action="deleteItem" data-item-id="{{id}}" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">No weapons.</p>
    {{/if}}
  </div>

  {{!-- Equipment --}}
  <div class="item-section">
    <div class="item-section-hdr">
      <h3 class="section-heading">Equipment</h3>
      {{#if isEditable}}
      <button type="button" class="add-btn icon-btn"
        data-action="createItem" data-type="equipment" title="Add Equipment">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if itemGroups.equipment.length}}
    <ul class="items-list" data-reorder-list data-reorder-mode="sort">
      {{#each itemGroups.equipment}}
      <li class="item-row{{#if equipped}} equipped{{/if}}{{#if attuned}} attuned{{/if}}" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-tag muted">{{equipmentType}}</span>
        <span class="item-qty muted">×{{quantity}}</span>
        <div class="item-controls">
          <button type="button" class="{{#if equipped}}active{{/if}}"
            data-action="toggleEquip" data-item-id="{{id}}" title="Equip/Unequip">
            <i class="fas fa-shield-alt"></i>
          </button>
          {{#if ../isEditable}}
          <button type="button"
            data-action="deleteItem" data-item-id="{{id}}" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">No equipment.</p>
    {{/if}}
  </div>

  {{!-- Consumables --}}
  <div class="item-section">
    <div class="item-section-hdr">
      <h3 class="section-heading">Consumables</h3>
      {{#if isEditable}}
      <button type="button" class="add-btn icon-btn"
        data-action="createItem" data-type="consumable" title="Add Consumable">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    {{#if itemGroups.consumables.length}}
    <ul class="items-list" data-reorder-list data-reorder-mode="sort">
      {{#each itemGroups.consumables}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img item-img-rollable" src="{{img}}" alt="{{name}}" data-action="useItem" title="Use {{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-tag muted">{{consumableType}}</span>
        <span class="item-qty muted">×{{quantity}}</span>
        <div class="item-controls">
          {{#if ../isEditable}}
          <button type="button"
            data-action="deleteItem" data-item-id="{{id}}" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="empty-note">No consumables.</p>
    {{/if}}
  </div>

  {{!-- Loot --}}
  {{#if itemGroups.loot.length}}
  <div class="item-section">
    <div class="item-section-hdr">
      <h3 class="section-heading">Loot</h3>
      {{#if isEditable}}
      <button type="button" class="add-btn icon-btn"
        data-action="createItem" data-type="loot" title="Add Loot">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </div>
    <ul class="items-list" data-reorder-list data-reorder-mode="sort">
      {{#each itemGroups.loot}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        <span class="item-qty muted">×{{quantity}}</span>
        <div class="item-controls">
          {{#if ../isEditable}}
          <button type="button"
            data-action="deleteItem" data-item-id="{{id}}" title="Delete">
            <i class="fas fa-trash"></i>
          </button>
          {{/if}}
        </div>
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

</section>
