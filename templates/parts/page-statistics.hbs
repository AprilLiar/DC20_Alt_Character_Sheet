<section class="page-scroll" data-page="statistics">
  <div class="stats-layout">

    {{!-- Roll Statistics --}}
    <div class="stats-table">
      <div class="stats-section-head">
        <span class="stats-sec-title">{{localize "DC20AltSheet.stats.rollStats"}}</span>
        <span class="stats-sec-col">{{localize "DC20AltSheet.stats.allTime"}}</span>
        <span class="stats-sec-col">{{localize "DC20AltSheet.stats.session"}}</span>
      </div>
      <div class="stats-tr">
        <span class="stats-tc-label">{{localize "DC20AltSheet.stats.avgD20"}}</span>
        <span class="stats-tc-life">{{d20Avg}}</span>
        <span class="stats-tc-sess">{{sessD20Avg}}</span>
      </div>
      <div class="stats-tr">
        <span class="stats-tc-label">{{localize "DC20AltSheet.stats.totalRolls"}}</span>
        <span class="stats-tc-life">{{d20Count}}</span>
        <span class="stats-tc-sess">{{sessD20Count}}</span>
      </div>
      <div class="stats-tr stats-row-good">
        <span class="stats-tc-label">{{localize "DC20AltSheet.stats.natural20s"}}</span>
        <span class="stats-tc-life">{{nat20}}</span>
        <span class="stats-tc-sess">{{sessNat20}}</span>
      </div>
      <div class="stats-tr stats-row-bad">
        <span class="stats-tc-label">{{localize "DC20AltSheet.stats.natural1s"}}</span>
        <span class="stats-tc-life">{{nat1}}</span>
        <span class="stats-tc-sess">{{sessNat1}}</span>
      </div>
    </div>

    {{!-- Damage --}}
    <div class="stats-table">
      <div class="stats-section-head">
        <span class="stats-sec-title">{{localize "DC20AltSheet.stats.damage"}}</span>
        <span class="stats-sec-col">{{localize "DC20AltSheet.stats.allTime"}}</span>
        <span class="stats-sec-col">{{localize "DC20AltSheet.stats.session"}}</span>
      </div>
      <div class="stats-subsec">{{localize "DC20AltSheet.stats.dealt"}}</div>
      <div class="stats-tr">
        <span class="stats-tc-label stats-tc-indent">{{localize "DC20AltSheet.stats.highest"}}</span>
        <span class="stats-tc-life">{{dealtHighest}}</span>
        <span class="stats-tc-sess">{{sessDealtHighest}}</span>
      </div>
      <div class="stats-tr">
        <span class="stats-tc-label stats-tc-indent">{{localize "DC20AltSheet.stats.lowest"}}</span>
        <span class="stats-tc-life">{{dealtLowest}}</span>
        <span class="stats-tc-sess">{{sessDealtLowest}}</span>
      </div>
      <div class="stats-tr stats-tr-total">
        <span class="stats-tc-label stats-tc-indent">{{localize "DC20AltSheet.stats.total"}}</span>
        <span class="stats-tc-life">{{dealtTotal}}</span>
        <span class="stats-tc-sess">{{sessDealtTotal}}</span>
      </div>
      <div class="stats-subsec">{{localize "DC20AltSheet.stats.taken"}}</div>
      <div class="stats-tr">
        <span class="stats-tc-label stats-tc-indent">{{localize "DC20AltSheet.stats.highest"}}</span>
        <span class="stats-tc-life">{{takenHighest}}</span>
        <span class="stats-tc-sess">{{sessTakenHighest}}</span>
      </div>
      <div class="stats-tr">
        <span class="stats-tc-label stats-tc-indent">{{localize "DC20AltSheet.stats.lowest"}}</span>
        <span class="stats-tc-life">{{takenLowest}}</span>
        <span class="stats-tc-sess">{{sessTakenLowest}}</span>
      </div>
      <div class="stats-tr stats-tr-total">
        <span class="stats-tc-label stats-tc-indent">{{localize "DC20AltSheet.stats.total"}}</span>
        <span class="stats-tc-life">{{takenTotal}}</span>
        <span class="stats-tc-sess">{{sessTakenTotal}}</span>
      </div>
    </div>

    {{!-- Top Used --}}
    {{#if topUsed}}
    <div class="stats-table">
      <div class="stats-section-head">
        <span class="stats-sec-title">{{localize "DC20AltSheet.stats.topUsed"}}</span>
        <span class="stats-sec-col">{{localize "DC20AltSheet.stats.allTime"}}</span>
        <span class="stats-sec-col">{{localize "DC20AltSheet.stats.session"}}</span>
      </div>
      {{#each topUsed}}
      <div class="stats-tr">
        <span class="stats-tc-label stats-tc-rollable">
          {{#if img}}<img class="stats-rollable-img" src="{{img}}" alt="">{{/if}}
          <span class="stats-rollable-badge stats-type-{{type}}">{{type}}</span>
          <span class="stats-rollable-name">{{name}}</span>
        </span>
        <span class="stats-tc-life">{{count}}</span>
        <span class="stats-tc-sess">{{sessCount}}</span>
      </div>
      {{/each}}
    </div>
    {{/if}}

    {{!-- Reset --}}
    {{#if isEditable}}
    <div class="stats-reset-wrap">
      <button type="button" class="stats-reset-btn" data-action="resetStats"
        title="{{localize "DC20AltSheet.stats.resetTitle"}}">
        {{localize "DC20AltSheet.stats.resetBtn"}}
      </button>
    </div>
    {{/if}}

  </div>
</section>
