<div class="tab tab-body" data-group="primary" data-tab="tab-main">
  <div class="main-layout">

    <!-- Attributes Column -->
    <div class="attributes-section">
      <h3 class="section-title">{{localize "DC20AltSheet.section.attributes"}}</h3>
      <div class="attributes-grid">
        {{#each attributes}}
        <div class="attribute-block" data-attr="{{key}}">
          <div class="attr-header">
            <span class="attr-name">{{localize label}}</span>
            <span class="attr-abbr">{{key}}</span>
          </div>
          <div class="attr-score rollable" data-action="rollAttribute" title="{{localize "DC20AltSheet.roll.checkHint"}}">
            {{current}}
          </div>
          <div class="attr-footer">
            <button class="attr-check rollable" type="button"
              data-action="rollAttribute"
              title="{{localize "DC20AltSheet.roll.check"}}">
              <i class="fas fa-dice-d20"></i>
              <span>{{signedNum check}}</span>
            </button>
            <button class="attr-save" type="button"
              data-action="rollSave"
              title="{{localize "DC20AltSheet.roll.save"}}">
              <i class="fas fa-shield-alt"></i>
              <span>{{signedNum save}}</span>
            </button>
          </div>
          {{#if saveMastery}}
            <div class="save-mastery" title="{{localize "DC20AltSheet.attr.saveMastery"}}">
              <i class="fas fa-star"></i>
            </div>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>

    <!-- Skills Column -->
    <div class="skills-section">
      <h3 class="section-title">{{localize "DC20AltSheet.section.skills"}}</h3>

      {{#if skills.length}}
      <div class="skills-list">
        {{#each skills}}
        <div class="skill-row" data-skill="{{key}}">
          <div class="skill-profs">
            {{profDots (or value 0) 2}}
          </div>
          <span class="skill-name rollable" data-action="rollSkill">
            {{#if label}}{{label}}{{else}}{{key}}{{/if}}
          </span>
          <span class="skill-attr muted">{{attribute}}</span>
          <span class="skill-bonus rollable" data-action="rollSkill">
            {{signedNum bonus}}
          </span>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="empty-note">{{localize "DC20AltSheet.empty.skills"}}</p>
      {{/if}}

      <!-- Languages -->
      {{#if languages}}
      <h3 class="section-title mt">{{localize "DC20AltSheet.section.languages"}}</h3>
      <div class="skills-list">
        {{#each languages as |lang key|}}
        <div class="skill-row" data-skill="{{key}}">
          <div class="skill-profs">{{profDots (or lang.value 0) 2}}</div>
          <span class="skill-name">{{#if lang.label}}{{lang.label}}{{else}}{{key}}{{/if}}</span>
          <span class="skill-bonus">{{signedNum lang.bonus}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </div>

    <!-- Movement & Senses Column -->
    <div class="movement-section">
      <h3 class="section-title">{{localize "DC20AltSheet.section.movement"}}</h3>
      <div class="movement-grid">
        {{#each movement as |mv key|}}
        {{#if (or mv.value mv.bonus)}}
        <div class="movement-row">
          <span class="mv-label">{{#if mv.label}}{{mv.label}}{{else}}{{key}}{{/if}}</span>
          <span class="mv-value">{{mv.current}}<span class="unit">ft</span></span>
        </div>
        {{/if}}
        {{/each}}
      </div>

      <h3 class="section-title mt">{{localize "DC20AltSheet.section.senses"}}</h3>
      <div class="movement-grid">
        {{#each senses as |sense key|}}
        {{#if sense.range}}
        <div class="movement-row">
          <span class="mv-label">{{#if sense.label}}{{sense.label}}{{else}}{{key}}{{/if}}</span>
          <span class="mv-value">{{sense.range}}<span class="unit">ft</span></span>
        </div>
        {{/if}}
        {{/each}}
      </div>

      <!-- Death Saves -->
      <h3 class="section-title mt">{{localize "DC20AltSheet.section.death"}}</h3>
      <div class="death-row">
        <span>{{localize "DC20AltSheet.death.threshold"}}</span>
        <input type="number" name="system.death.threshold" value="{{death.threshold}}"
          {{#unless isEditable}}disabled{{/unless}}>
      </div>

      <!-- Size -->
      <div class="size-row mt">
        <span class="mv-label">{{localize "DC20AltSheet.section.size"}}</span>
        <span class="mv-value">{{size}}</span>
      </div>
    </div>

  </div>
</div>
