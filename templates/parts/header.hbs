<div class="sheet-header-strip">

  {{!-- Action Points: pips --}}
  <div class="hstrip-resource ap-strip">
    <span class="hstrip-label">AP</span>
    <div class="ap-pips-strip">
      {{{apPips header.ap.value header.ap.max}}}
    </div>
  </div>

  <div class="hstrip-divider"></div>

  {{!-- Hit Points --}}
  <div class="hstrip-resource hp-strip">
    <span class="hstrip-label hp-label">HP</span>
    <div class="hstrip-bar-wrap hp-bar">
      <div class="hstrip-bar-fill" style="width: {{percent header.hp.value header.hp.max}}%"></div>
      <div class="hstrip-bar-text">
        <input type="number" name="system.resources.health.value"
          value="{{header.hp.value}}" class="hstrip-input"
          {{#unless isEditable}}disabled{{/unless}}>
        <span class="hstrip-sep">/</span>
        <input type="number" name="system.resources.health.max"
          value="{{header.hp.max}}" class="hstrip-input"
          {{#unless isEditable}}disabled{{/unless}}>
      </div>
    </div>
  </div>

  <div class="hstrip-divider"></div>

  {{!-- Stamina Points --}}
  <div class="hstrip-resource sp-strip">
    <span class="hstrip-label sp-label">SP</span>
    <div class="hstrip-bar-wrap sp-bar">
      <div class="hstrip-bar-fill" style="width: {{percent header.stamina.value header.stamina.max}}%"></div>
      <div class="hstrip-bar-text">
        <input type="number" name="system.resources.stamina.value"
          value="{{header.stamina.value}}" class="hstrip-input"
          {{#unless isEditable}}disabled{{/unless}}>
        <span class="hstrip-sep">/</span>
        <input type="number" name="system.resources.stamina.max"
          value="{{header.stamina.max}}" class="hstrip-input"
          {{#unless isEditable}}disabled{{/unless}}>
      </div>
    </div>
  </div>

  <div class="hstrip-divider"></div>

  {{!-- Mana Points --}}
  <div class="hstrip-resource mp-strip">
    <span class="hstrip-label mp-label">MP</span>
    <div class="hstrip-bar-wrap mp-bar">
      <div class="hstrip-bar-fill" style="width: {{percent header.mana.value header.mana.max}}%"></div>
      <div class="hstrip-bar-text">
        <input type="number" name="system.resources.mana.value"
          value="{{header.mana.value}}" class="hstrip-input"
          {{#unless isEditable}}disabled{{/unless}}>
        <span class="hstrip-sep">/</span>
        <input type="number" name="system.resources.mana.max"
          value="{{header.mana.max}}" class="hstrip-input"
          {{#unless isEditable}}disabled{{/unless}}>
      </div>
    </div>
  </div>

  <div class="hstrip-divider"></div>

  {{!-- Quick Access Slots --}}
  <div class="hstrip-quick-slots">
    {{#each header.quickSlots}}
    <div class="quick-slot{{#if this}} filled{{/if}}" data-slot-index="{{@index}}">
      {{#if this}}
        {{#if abbr}}<span class="qs-abbr" title="{{label}}">{{abbr}}</span>
        {{else if img}}<img class="qs-img" src="{{img}}" alt="{{label}}" title="{{label}}">
        {{else}}<span class="qs-label" title="{{label}}">{{label}}</span>{{/if}}
      {{else}}
        <span class="qs-empty-hint">+</span>
      {{/if}}
    </div>
    {{/each}}
    <button type="button" class="qs-add-btn" data-action="addQuickSlot" title="Add quick-access slot">+</button>
  </div>

</div>
