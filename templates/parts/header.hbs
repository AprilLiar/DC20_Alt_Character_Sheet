{{!-- Reusable resource bar (value / max) — branches on resource kind --}}
{{#*inline "resBar"}}
<div class="hstrip-bar-wrap">
  <div class="hstrip-bar-fill" style="width: {{pct}}%; background: {{color}};"></div>
  <div class="hstrip-bar-text">
    <input type="number" class="hstrip-input" name="{{valuePath}}" value="{{value}}"
      {{#unless @root.isEditable}}disabled{{/unless}}>
    {{#if hasMax}}
      <span class="hstrip-sep">/</span>
      {{#if maxPath}}
        <input type="number" class="hstrip-input" name="{{maxPath}}" value="{{max}}"
          {{#unless @root.isEditable}}disabled{{/unless}}>
      {{else}}
        <span class="hstrip-maxval">{{max}}</span>
      {{/if}}
    {{/if}}
  </div>
</div>
{{/inline}}

<div class="sheet-header-strip">

  {{!-- Action Points: pips --}}
  <div class="hstrip-resource ap-strip">
    <span class="hstrip-label">AP</span>
    <div class="ap-pips-strip">
      {{{apPips header.ap.value header.ap.max}}}
    </div>
  </div>

  {{!-- Defences: PD / AD --}}
  {{#if (or (ne header.pd null) (ne header.ad null))}}
  <div class="hstrip-defences" title="Precision Defence / Area Defence">
    <div class="hstrip-def pd-def">
      <span class="hstrip-def-label">PD</span>
      <span class="hstrip-def-val">{{#if (ne header.pd null)}}{{header.pd}}{{else}}—{{/if}}</span>
    </div>
    <div class="hstrip-def ad-def">
      <span class="hstrip-def-label">AD</span>
      <span class="hstrip-def-val">{{#if (ne header.ad null)}}{{header.ad}}{{else}}—{{/if}}</span>
    </div>
  </div>
  {{/if}}

  <div class="hstrip-divider"></div>

  {{!-- Resource dropdown: collapsed selected resource + full list --}}
  {{#if header.selected}}
  <div class="hstrip-resource hstrip-dd">
    <button type="button" class="hstrip-dd-toggle" title="Switch / manage resources">
      <span class="hstrip-label hstrip-dd-label">{{header.selected.label}}</span>
      {{> resBar header.selected}}
      <i class="fas fa-caret-down hstrip-dd-caret"></i>
    </button>

    <div class="hstrip-dd-panel hidden">
      <div class="hstrip-dd-title">Resources</div>
      {{#each header.resources}}
      <div class="res-row{{#if (eq key @root.header.selected.key)}} selected{{/if}}{{#if removable}} res-removable{{/if}}"
        data-res-key="{{key}}"{{#if removable}} data-res-custom-key="{{customKey}}"{{/if}}>
        <span class="res-name" data-select-resource="{{key}}"
          title="{{#if removable}}Show in header · right-click row to remove{{else}}Show in header{{/if}}">{{label}}</span>
        {{> resBar this}}
      </div>
      {{/each}}

      {{#if isEditable}}
      <div class="res-create">
        <input type="text" class="res-create-name" placeholder="New tracker…" maxlength="24">
        <input type="color" class="res-create-color" value="#9988cc" title="Bar colour">
        <button type="button" class="res-create-btn" title="Create tracker"><i class="fas fa-plus"></i></button>
      </div>
      {{/if}}
    </div>
  </div>
  {{/if}}

  <div class="hstrip-divider"></div>

  {{!-- Quick Access Slots --}}
  <div class="hstrip-quick-slots">
    {{#each header.quickSlots}}
    <div class="quick-slot{{#if this}} filled{{/if}}" data-slot-index="{{@index}}">
      {{#if this}}
        {{#if abbr}}<span class="qs-abbr" title="{{label}}">{{abbr}}</span>
        {{else if img}}<img class="qs-img" src="{{img}}" alt="{{label}}" title="{{label}}">
        {{else}}<span class="qs-label" title="{{label}}">{{label}}</span>{{/if}}
      {{/if}}
    </div>
    {{/each}}
    <button type="button" class="qs-add-btn" title="Add quick slot">+</button>
  </div>

</div>
