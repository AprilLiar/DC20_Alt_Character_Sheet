<section class="page-scroll" data-page="features">

  <div class="page-section-header">
    <h3 class="section-heading">Passive Features</h3>
    {{#if isEditable}}
    <button type="button" class="add-btn"
      data-action="createItem" data-type="feature">
      <i class="fas fa-plus"></i> Add Feature
    </button>
    {{/if}}
  </div>

  {{!-- Class --}}
  {{#if featureGroups.class.length}}
  <div class="feature-group">
    <h4 class="feature-source-heading">Class</h4>
    <ul class="items-list">
      {{#each featureGroups.class}}
      <li class="item-row" data-item-id="{{id}}">
        <img class="item-img" src="{{img}}" alt="{{name}}">
        <span class="item-name">{{name}}</span>
        {{#if featureType}}<span class="item-tag muted">{{featureType}}</span>{{/if}}
        {{#if ../isEditable}}
        <div class="item-controls">
          <button type="button" data-action="editItem" data-item-id="{{id}}" title="Edit"><i class="fas fa-pencil-alt"></i></button>
          <button type="button" data-action="deleteItem" data-item-id="{{id}}" title="Delete"><i class="fas fa-trash"></i></button>
        </div>
        {{/if}}
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{!-- Subclass --}}
  {{#if featureGroups.subclass.length}}
