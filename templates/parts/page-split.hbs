{{#if split}}
  {{!-- 3+ pane splits always use this hardcoded "vertical-style" grid layout,
       regardless of the vertical/horizontal orientation chosen when the split
       was built — that toggle only applies to the plain 2-pane case below. --}}
  {{#if split.bottomRight}}
  <div class="split-view-4 active" data-split-id="{{split.id}}">
    <div class="split-row-top" style="flex-grow: {{split.topGrow}}">
      <div class="split-pane split-pane-left" data-page="{{split.left}}" style="flex-grow: {{split.leftGrow}}">
        {{> (concat "dc20-split-" split.left) leftCtx}}
      </div>
      <div class="split-divider split-divider-v" title="{{localize "DC20AltSheet.nav.dragToResize"}}"></div>
      <div class="split-pane split-pane-right" data-page="{{split.right}}" style="flex-grow: {{split.rightGrow}}">
        {{> (concat "dc20-split-" split.right) rightCtx}}
      </div>
    </div>
    <div class="split-divider split-divider-h" title="{{localize "DC20AltSheet.nav.dragToResize"}}"></div>
    <div class="split-row-bottom" style="flex-grow: {{split.bottomGrow}}">
      <div class="split-pane split-pane-bottom-left" data-page="{{split.bottom}}" style="flex-grow: {{split.bottomLeftGrow}}">
        {{> (concat "dc20-split-" split.bottom) bottomCtx}}
      </div>
      <div class="split-divider split-divider-v split-divider-v-bottom" title="{{localize "DC20AltSheet.nav.dragToResize"}}"></div>
      <div class="split-pane split-pane-bottom-right" data-page="{{split.bottomRight}}" style="flex-grow: {{split.bottomRightGrow}}">
        {{> (concat "dc20-split-" split.bottomRight) bottomRightCtx}}
      </div>
    </div>
  </div>
  {{else if split.bottom}}
  <div class="split-view-3 active" data-split-id="{{split.id}}">
    <div class="split-row-top" style="flex-grow: {{split.topGrow}}">
      <div class="split-pane split-pane-left" data-page="{{split.left}}" style="flex-grow: {{split.leftGrow}}">
        {{> (concat "dc20-split-" split.left) leftCtx}}
      </div>
      <div class="split-divider split-divider-v" title="{{localize "DC20AltSheet.nav.dragToResize"}}"></div>
      <div class="split-pane split-pane-right" data-page="{{split.right}}" style="flex-grow: {{split.rightGrow}}">
        {{> (concat "dc20-split-" split.right) rightCtx}}
      </div>
    </div>
    <div class="split-divider split-divider-h" title="{{localize "DC20AltSheet.nav.dragToResize"}}"></div>
    <div class="split-row-bottom" style="flex-grow: {{split.bottomGrow}}">
      <div class="split-pane split-pane-bottom" data-page="{{split.bottom}}">
        {{> (concat "dc20-split-" split.bottom) bottomCtx}}
      </div>
    </div>
  </div>
  {{else if split.isHorizontal}}
  <div class="split-view-h active" data-split-id="{{split.id}}">
    <div class="split-pane split-pane-left" data-page="{{split.left}}" style="flex-grow: {{split.leftGrow}}">
      {{> (concat "dc20-split-" split.left) leftCtx}}
    </div>
    <div class="split-divider split-divider-h" title="{{localize "DC20AltSheet.nav.dragToResize"}}"></div>
    <div class="split-pane split-pane-right" data-page="{{split.right}}" style="flex-grow: {{split.rightGrow}}">
      {{> (concat "dc20-split-" split.right) rightCtx}}
    </div>
  </div>
  {{else}}
  <div class="split-view active" data-split-id="{{split.id}}">
    <div class="split-pane split-pane-left" data-page="{{split.left}}" style="flex-grow: {{split.leftGrow}}">
      {{> (concat "dc20-split-" split.left) leftCtx}}
    </div>
    <div class="split-divider split-divider-v" title="{{localize "DC20AltSheet.nav.dragToResize"}}"></div>
    <div class="split-pane split-pane-right" data-page="{{split.right}}" style="flex-grow: {{split.rightGrow}}">
      {{> (concat "dc20-split-" split.right) rightCtx}}
    </div>
  </div>
  {{/if}}
{{else}}
<div class="split-view" data-split-empty="1"></div>
{{/if}}
