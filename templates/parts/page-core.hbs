<section class="page-scroll" data-page="core">
  <div class="core-grid">

    {{!-- NORTH: Meta stats + Attribute cards --}}
    <div class="core-panel core-north">
      <div class="core-north-content">
        <div class="core-meta-chips">
          {{#if details.level}}
          <div class="core-chip">
            <span class="chip-label">{{localize "DC20AltSheet.core.lvl"}}</span>
            <span class="chip-val">{{details.level}}</span>
          </div>
          {{/if}}
          {{#if details.combatMastery}}
          <div class="core-chip">
            <span class="chip-label">{{localize "DC20AltSheet.core.cm"}}</span>
            <span class="chip-val">+{{details.combatMastery}}</span>
          </div>
          {{/if}}
          <div class="core-chip">
            <span class="chip-label">{{localize "DC20AltSheet.core.size"}}</span>
            {{#if isEditable}}
              <select class="chip-size-select" name="system.size.size">
                <option value="tiny"       {{#if (eq size "tiny")}}selected{{/if}}>{{localize "DC20AltSheet.size.tiny"}}</option>
                <option value="small"      {{#if (eq size "small")}}selected{{/if}}>{{localize "DC20AltSheet.size.small"}}</option>
                <option value="medium"     {{#if (eq size "medium")}}selected{{/if}}>{{localize "DC20AltSheet.size.medium"}}</option>
                <option value="large"      {{#if (eq size "large")}}selected{{/if}}>{{localize "DC20AltSheet.size.large"}}</option>
                <option value="huge"       {{#if (eq size "huge")}}selected{{/if}}>{{localize "DC20AltSheet.size.huge"}}</option>
                <option value="gargantuan" {{#if (eq size "gargantuan")}}selected{{/if}}>{{localize "DC20AltSheet.size.gargantuan"}}</option>
                <option value="colossal"   {{#if (eq size "colossal")}}selected{{/if}}>{{localize "DC20AltSheet.size.colossal"}}</option>
                <option value="titanic"    {{#if (eq size "titanic")}}selected{{/if}}>{{localize "DC20AltSheet.size.titanic"}}</option>
              </select>
            {{else}}
              <span class="chip-val">{{#if size}}{{size}}{{else}}—{{/if}}</span>
            {{/if}}
          </div>
          {{#each movement}}
          <div class="core-chip">
            <span class="chip-label">{{label}}</span>
            <span class="chip-val">{{value}}</span>
          </div>
          {{/each}}
          {{#each senses}}
          <div class="core-chip">
            <span class="chip-label">{{label}}</span>
            <span class="chip-val">{{range}}<span class="chip-unit"> ft</span></span>
          </div>
          {{/each}}
        </div>

        <div class="sc-attrs">
          {{#each attributes}}
          <div class="sc-attr" data-attr="{{key}}" title="{{label}}">
            <span class="sc-attr-name">{{abbr}}</span>
            <span class="sc-attr-score">{{signedNum value}}</span>
            <div class="sc-attr-buttons">
              <button type="button" class="sc-attr-btn rollable" data-action="rollAttribute" data-attr="{{key}}" title="{{localize "DC20AltSheet.core.check"}}">
                <i class="fas fa-dice-d20"></i>{{signedNum check}}
              </button>
              <button type="button" class="sc-attr-btn rollable" data-action="rollSave" data-attr="{{key}}" title="{{localize "DC20AltSheet.core.save"}}">
                <i class="fas fa-shield-alt"></i>{{signedNum save}}
              </button>
            </div>
          </div>
          {{/each}}
        </div>
      </div>
    </div>

    {{!-- WEST: Skills / Trades (toggleable sub-tabs) + Languages --}}
    <div class="core-panel core-west">
      <div class="core-subtabs core-panel-header" role="tablist">
        <button type="button" class="core-subtab-btn{{#unless (eq coreSkillTab 'trades')}} active{{/unless}}"
          data-core-subtab="skills">{{localize "DC20AltSheet.core.skills"}}</button>
        <button type="button" class="core-subtab-btn{{#if (eq coreSkillTab 'trades')}} active{{/if}}"
          data-core-subtab="trades">{{localize "DC20AltSheet.core.trades"}}</button>
      </div>
      <div class="core-panel-scroll">

        {{!-- Skills sub-panel --}}
        <div class="core-subpanel core-subpanel-skills{{#if (eq coreSkillTab 'trades')}} hidden{{/if}}" data-core-subpanel="skills">
          {{#if skills.length}}
            <div class="skills-list">
              {{#each skills}}
              <div class="skill-row" data-skill="{{key}}">
                <span class="skill-profs">{{{profDots mastery 5}}}</span>
                <span class="skill-name rollable" data-action="rollSkill" data-skill="{{key}}">{{label}}</span>
                <span class="skill-bonus rollable" data-action="rollSkill" data-skill="{{key}}">{{signedNum bonus}}</span>
              </div>
              {{/each}}
            </div>
          {{else}}
            <p class="empty-note">{{localize "DC20AltSheet.empty.skills"}}</p>
          {{/if}}

          {{#if languages.length}}
            <h3 class="section-heading mt">{{localize "DC20AltSheet.core.languages"}}</h3>
            <div class="skills-list">
              {{#each languages}}
              <div class="skill-row lang-row">
                <span class="skill-profs">{{{profDots mastery 2}}}</span>
                <span class="skill-name">{{label}}</span>
              </div>
              {{/each}}
            </div>
          {{/if}}
        </div>

        {{!-- Trades sub-panel --}}
        <div class="core-subpanel core-subpanel-trades{{#unless (eq coreSkillTab 'trades')}} hidden{{/unless}}" data-core-subpanel="trades">
          {{#if trades.length}}
            <div class="skills-list">
              {{#each trades}}
              <div class="skill-row" data-trade="{{key}}">
                <span class="skill-profs">{{{profDots mastery 5}}}</span>
                <span class="skill-name rollable" data-action="rollTrade" data-trade="{{key}}">{{label}}</span>
                <span class="skill-bonus rollable" data-action="rollTrade" data-trade="{{key}}">{{signedNum bonus}}</span>
              </div>
              {{/each}}
            </div>
          {{else}}
            <p class="empty-note">{{localize "DC20AltSheet.empty.trades"}}</p>
          {{/if}}
        </div>

      </div>
    </div>

    {{!-- CENTER: Portrait (the centrepiece) --}}
    <div class="core-portrait-zone">
      <div class="portrait-frame">
        <div class="portrait-frame-inner">
          <img class="portrait-img" src="{{portrait}}" alt="{{actorName}}"
            {{#if isEditable}}data-edit="img"{{/if}}>
        </div>
        <span class="portrait-corner tl" aria-hidden="true"></span>
        <span class="portrait-corner tr" aria-hidden="true"></span>
        <span class="portrait-corner bl" aria-hidden="true"></span>
        <span class="portrait-corner br" aria-hidden="true"></span>
      </div>
      <div class="identity-block">
        <div class="char-name">{{actorName}}</div>
        <div class="char-meta">
          {{#if details.class.name}}<span class="char-meta-item">{{details.class.name}}</span>{{/if}}
          {{#if details.subclass.name}}<span class="char-meta-item muted"> · {{details.subclass.name}}</span>{{/if}}
          {{#if details.ancestry.name}}<span class="char-meta-item">{{details.ancestry.name}}</span>{{/if}}
          {{#if details.background.name}}<span class="char-meta-item muted"> · {{details.background.name}}</span>{{/if}}
        </div>
      </div>
    </div>

    {{!-- EAST: Roll tiles (basic checks + custom rolls) --}}
    <div class="core-panel core-east">
      <h3 class="section-heading core-panel-header">{{localize "DC20AltSheet.core.rolls"}}</h3>
      <div class="core-panel-scroll">
        <div class="roll-tiles">
          {{#each basicRolls}}
          <button type="button" class="roll-tile roll-tile-basic" draggable="true"
            data-action="rollBasic" data-roll-key="{{key}}" data-roll-label="{{label}}"
            title="{{localize "DC20AltSheet.use"}} {{label}}">
            <span class="roll-tile-name">{{label}}</span>
          </button>
          {{/each}}

          {{#each customRolls}}
          <button type="button" class="roll-tile roll-tile-custom" draggable="true"
            data-action="rollCustom" data-roll-id="{{id}}" data-roll-name="{{name}}" data-roll-bonus="{{bonus}}"
            title="{{localize "DC20AltSheet.use"}} {{name}}">
            <span class="roll-tile-name">{{name}}</span>
            <span class="roll-tile-bonus">{{signedNum bonus}}</span>
          </button>
          {{/each}}
        </div>

        {{#if isEditable}}
        <button type="button" class="roll-tile-add" data-action="addCustomRoll" title="{{localize "DC20AltSheet.core.createCustomRoll"}}">
          <i class="fas fa-plus"></i>
        </button>
        {{/if}}
      </div>
    </div>

    {{!-- SOUTH: Favourites (left) | Last Used (right) --}}
    <div class="core-south">

      <div class="core-panel">
        <h3 class="section-heading core-panel-header">{{localize "DC20AltSheet.core.favourites"}}</h3>
        <div class="core-panel-scroll">
          {{#if favourites.length}}
            <ul class="qol-list" data-reorder-list data-reorder-mode="flag" data-reorder-key="favourites">
              {{#each favourites}}
              <li class="qol-row" data-item-id="{{id}}">
                <img class="qol-img" src="{{img}}" alt="{{name}}"
                  data-action="useItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.use"}} {{name}}">
                <span class="qol-name">{{name}}</span>
              </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="empty-note">{{localize "DC20AltSheet.empty.favourites"}}</p>
          {{/if}}
        </div>
      </div>

      <div class="core-panel">
        <h3 class="section-heading core-panel-header">{{localize "DC20AltSheet.core.lastUsed"}}</h3>
        <div class="core-panel-scroll">
          {{#if lastUsed.length}}
            <ul class="qol-list" data-reorder-list data-reorder-mode="flag" data-reorder-key="lastUsed">
              {{#each lastUsed}}
              <li class="qol-row" data-item-id="{{id}}">
                <img class="qol-img" src="{{img}}" alt="{{name}}"
                  data-action="useItem" data-item-id="{{id}}" title="{{localize "DC20AltSheet.use"}} {{name}}">
                <span class="qol-name">{{name}}</span>
              </li>
              {{/each}}
            </ul>
          {{else}}
            <p class="empty-note">{{localize "DC20AltSheet.empty.lastUsed"}}</p>
          {{/if}}
        </div>
      </div>

    </div>

  </div>
</section>
