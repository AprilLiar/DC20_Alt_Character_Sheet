<div class="tab tab-body" data-group="primary" data-tab="tab-combat">

  <!-- Resources Row -->
  <div class="combat-resources">
    <h3 class="section-title">{{localize "DC20AltSheet.section.resources"}}</h3>
    <div class="resources-grid">

      <div class="resource-card hp">
        <div class="res-icon"><i class="fas fa-heart"></i></div>
        <div class="res-info">
          <div class="res-label">{{localize "DC20AltSheet.resource.hp"}}</div>
          <div class="res-bar">
            <div class="res-fill" style="width: {{percent resources.health.value resources.health.max}}%"></div>
          </div>
          <div class="res-values">
            <input type="number" name="system.resources.health.value" value="{{resources.health.value}}"
              {{#unless isEditable}}disabled{{/unless}}>
            <span>/</span>
            <input type="number" name="system.resources.health.max" value="{{resources.health.max}}"
              {{#unless isEditable}}disabled{{/unless}}>
          </div>
          {{#if resources.health.temp}}
          <div class="res-temp">Temp: <input type="number" name="system.resources.health.temp"
            value="{{resources.health.temp}}" {{#unless isEditable}}disabled{{/unless}}></div>
          {{/if}}
        </div>
      </div>

      <div class="resource-card ap">
        <div class="res-icon"><i class="fas fa-bolt"></i></div>
        <div class="res-info">
          <div class="res-label">{{localize "DC20AltSheet.resource.ap"}}</div>
          <div class="ap-pips-large">
            {{apPips resources.ap.value 4}}
          </div>
          <div class="res-values">
            <input type="number" name="system.resources.ap.value" value="{{resources.ap.value}}"
              min="0" max="4" {{#unless isEditable}}disabled{{/unless}}>
            <span>/ 4</span>
          </div>
        </div>
      </div>

      <div class="resource-card stamina">
        <div class="res-icon"><i class="fas fa-fist-raised"></i></div>
        <div class="res-info">
          <div class="res-label">{{localize "DC20AltSheet.resource.stamina"}}</div>
          <div class="res-bar">
            <div class="res-fill" style="width: {{percent resources.stamina.value resources.stamina.max}}%"></div>
          </div>
          <div class="res-values">
            <input type="number" name="system.resources.stamina.value" value="{{resources.stamina.value}}"
              {{#unless isEditable}}disabled{{/unless}}>
            <span>/</span>
            <span>{{resources.stamina.max}}</span>
          </div>
        </div>
      </div>

      <div class="resource-card mana">
        <div class="res-icon"><i class="fas fa-magic"></i></div>
        <div class="res-info">
          <div class="res-label">{{localize "DC20AltSheet.resource.mana"}}</div>
          <div class="res-bar">
            <div class="res-fill" style="width: {{percent resources.mana.value resources.mana.max}}%"></div>
          </div>
          <div class="res-values">
            <input type="number" name="system.resources.mana.value" value="{{resources.mana.value}}"
              {{#unless isEditable}}disabled{{/unless}}>
            <span>/</span>
            <span>{{resources.mana.max}}</span>
          </div>
        </div>
      </div>

      <div class="resource-card grit">
        <div class="res-icon"><i class="fas fa-fire"></i></div>
        <div class="res-info">
          <div class="res-label">{{localize "DC20AltSheet.resource.grit"}}</div>
          <div class="res-bar">
            <div class="res-fill" style="width: {{percent resources.grit.value resources.grit.max}}%"></div>
          </div>
          <div class="res-values">
            <input type="number" name="system.resources.grit.value" value="{{resources.grit.value}}"
              {{#unless isEditable}}disabled{{/unless}}>
            <span>/</span>
            <span>{{resources.grit.max}}</span>
          </div>
        </div>
      </div>

      <div class="resource-card rest-points">
        <div class="res-icon"><i class="fas fa-moon"></i></div>
        <div class="res-info">
          <div class="res-label">{{localize "DC20AltSheet.resource.restPoints"}}</div>
          <div class="res-bar">
            <div class="res-fill" style="width: {{percent resources.restPoints.value resources.restPoints.max}}%"></div>
          </div>
          <div class="res-values">
            <input type="number" name="system.resources.restPoints.value" value="{{resources.restPoints.value}}"
              {{#unless isEditable}}disabled{{/unless}}>
            <span>/</span>
            <span>{{resources.restPoints.max}}</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Roll Modifiers -->
  <div class="roll-mods-row">
    <div class="roll-mod-card">
      <div class="rm-label">{{localize "DC20AltSheet.rollMod.saveDC"}}</div>
      <div class="rm-values">
        <span class="rm-sub">Spell {{saveDC.spell}}</span>
        <span class="rm-sub">Martial {{saveDC.martial}}</span>
      </div>
    </div>
    <div class="roll-mod-card">
      <div class="rm-label">{{localize "DC20AltSheet.rollMod.attack"}}</div>
      <div class="rm-values">
        <span class="rm-sub">Spell {{signedNum attackMod.spell}}</span>
        <span class="rm-sub">Martial {{signedNum attackMod.martial}}</span>
      </div>
    </div>
    <div class="roll-mod-card">
      <div class="rm-label">{{localize "DC20AltSheet.rollMod.check"}}</div>
      <div class="rm-values">
        <span class="rm-sub">Spell {{signedNum checkMod.spell}}</span>
        <span class="rm-sub">Martial {{signedNum checkMod.martial}}</span>
      </div>
    </div>
  </div>

  <!-- Conditions Grid -->
  <div class="conditions-section">
    <h3 class="section-title">{{localize "DC20AltSheet.section.conditions"}}</h3>
    <div class="conditions-grid">
      {{#each conditions as |cond key|}}
      <div class="condition-chip {{#if cond.active}}active{{/if}}" data-condition="{{key}}"
        title="{{#if cond.label}}{{cond.label}}{{else}}{{key}}{{/if}}">
        <span class="cond-name">{{#if cond.label}}{{cond.label}}{{else}}{{key}}{{/if}}</span>
        {{#if cond.immunity}}
          <span class="cond-badge immune" title="Immune"><i class="fas fa-ban"></i></span>
        {{else if cond.resistance}}
          <span class="cond-badge resist" title="Resistance: {{cond.resistance}}">{{cond.resistance}}</span>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>

  <!-- Damage Reductions -->
  <div class="dmg-reduction-section">
    <h3 class="section-title">{{localize "DC20AltSheet.section.damageReduction"}}</h3>
    <div class="dmg-reduction-grid">
      {{#with damageReduction}}
      {{#if flat}}
      <div class="dmr-row">
        <span class="dmr-label">{{localize "DC20AltSheet.dmr.flat"}}</span>
        <span class="dmr-val">{{flat}}</span>
      </div>
      {{/if}}
      {{#each reductions as |reduction key|}}
      {{#if reduction.active}}
      <div class="dmr-row">
        <span class="dmr-label">{{#if reduction.label}}{{reduction.label}}{{else}}{{key}}{{/if}}</span>
        <span class="dmr-badge">{{key}}</span>
      </div>
      {{/if}}
      {{/each}}
      {{/with}}
    </div>

    <!-- Per-type damage modifiers -->
    <h4 class="subsection-title">{{localize "DC20AltSheet.section.dmgTypes"}}</h4>
    <div class="dmg-types-grid">
      {{#each damageReduction.damageTypes as |dt key|}}
      <div class="dmg-type-row {{dt.category}}">
        <span class="dt-name">{{key}}</span>
        {{#if dt.immune}}<span class="dt-chip immune">IMM</span>{{/if}}
        {{#if dt.resist}}<span class="dt-chip resist">RES</span>{{/if}}
        {{#if dt.vulnerable}}<span class="dt-chip vuln">VUL</span>{{/if}}
      </div>
      {{/each}}
    </div>
  </div>

</div>
